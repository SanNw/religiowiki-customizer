{
	"name": "sannw/religiowiki-customizer",
	"description": "Painel administrativo de personalização de tema, homepage e componentes para a Religio Wiki (MediaWiki).",
	"type": "mediawiki-extension",
	"license": "GPL-2.0-or-later",
	"authors": [
		{ "name": "SanNw" }
	],
	"autoload": {
		"psr-4": {
			"MediaWiki\\Extension\\ReligiowikiCustomizer\\": "includes/"
		}
	},
	"require-dev": {
		"mediawiki/mediawiki-codesniffer": "^43.0",
		"mediawiki/minus-x": "^1.1",
		"php-parallel-lint/php-parallel-lint": "^1.3"
	},
	"scripts": {
		"test": [
			"parallel-lint . --exclude vendor",
			"phpcs -p -s",
			"minus-x check ."
		],
		"fix": [
			"minus-x fix .",
			"phpcbf"
		]
	}
}
