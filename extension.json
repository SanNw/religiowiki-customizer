{
	"name": "ReligiowikiCustomizer",
	"version": "1.0.0-phase8",
	"author": [ "SanNw" ],
	"url": "https://github.com/SanNw/religiowiki-customizer",
	"descriptionmsg": "religiowikicustomizer-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "specialpage",
	"requires": {
		"MediaWiki": ">= 1.39.0"
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\ReligiowikiCustomizer\\": "includes/"
	},
	"MessagesDirs": {
		"ReligiowikiCustomizer": [ "i18n" ]
	},
	"ExtensionMessagesFiles": {
		"ReligiowikiCustomizerMagic": "i18n/magic/ReligiowikiCustomizer.magic.php"
	},
	"SpecialPages": {
		"ReligiowikiCustomizer": {
			"class": "MediaWiki\\Extension\\ReligiowikiCustomizer\\SpecialPages\\SpecialReligiowikiCustomizer"
		},
		"Artigos": {
			"class": "MediaWiki\\Extension\\ReligiowikiCustomizer\\SpecialPages\\SpecialArtigos"
		}
	},
	"HookHandlers": {
		"religiowikiCustomizerMain": {
			"class": "MediaWiki\\Extension\\ReligiowikiCustomizer\\Hooks\\HookHandler"
		}
	},
	"Hooks": {
		"BeforePageDisplay": "religiowikiCustomizerMain",
		"LoadExtensionSchemaUpdates": "religiowikiCustomizerMain",
		"OutputPageBeforeHTML": "religiowikiCustomizerMain",
		"ParserFirstCallInit": "religiowikiCustomizerMain",
		"EditPage::showEditForm:initial": "religiowikiCustomizerMain"
	},
	"ResourceModules": {
		"ext.religiowikiCustomizer.theme": {
			"class": "MediaWiki\\Extension\\ReligiowikiCustomizer\\Theme\\ThemeResourceLoaderModule",
			"targets": [ "desktop", "mobile" ]
		},
		"ext.religiowikiCustomizer.customCss": {
			"class": "MediaWiki\\Extension\\ReligiowikiCustomizer\\Theme\\CustomCssResourceLoaderModule",
			"targets": [ "desktop", "mobile" ]
		},
		"ext.religiowikiCustomizer.customJs": {
			"class": "MediaWiki\\Extension\\ReligiowikiCustomizer\\Theme\\CustomJsResourceLoaderModule",
			"targets": [ "desktop", "mobile" ]
		},
		"ext.religiowikiCustomizer.chrome": {
			"scripts": [ "resources/js/chrome.js" ],
			"targets": [ "desktop", "mobile" ]
		},
		"ext.religiowikiCustomizer.special": {
			"styles": [ "resources/css/special-religiowikicustomizer.css" ],
			"scripts": [ "resources/js/special-religiowikicustomizer.js" ],
			"targets": [ "desktop", "mobile" ]
		},
		"ext.religiowikiCustomizer.homepage": {
			"styles": [ "resources/css/homepage.css" ],
			"targets": [ "desktop", "mobile" ]
		},
		"ext.religiowikiCustomizer.components": {
			"styles": [ "resources/css/components.css" ],
			"targets": [ "desktop", "mobile" ]
		},
		"ext.religiowikiCustomizer.componentsJs": {
			"scripts": [ "resources/js/components.js" ],
			"targets": [ "desktop", "mobile" ]
		},
		"ext.religiowikiCustomizer.widgets": {
			"styles": [ "resources/css/widgets.css" ],
			"targets": [ "desktop", "mobile" ]
		},
		"ext.religiowikiCustomizer.seo": {
			"styles": [ "resources/css/seo.css" ],
			"targets": [ "desktop", "mobile" ]
		},
		"ext.religiowikiCustomizer.lazyImages": {
			"scripts": [ "resources/js/lazy-images.js" ],
			"targets": [ "desktop", "mobile" ]
		},
		"ext.religiowikiCustomizer.editorToolbar": {
			"styles": [ "resources/css/editor-toolbar.css" ],
			"scripts": [ "resources/js/editor-toolbar.js" ],
			"targets": [ "desktop", "mobile" ]
		},
		"ext.religiowikiCustomizer.veEditorSidebar": {
			"styles": [ "resources/css/ve-editor-sidebar.css" ],
			"scripts": [ "resources/js/ve-editor-sidebar.js" ],
			"targets": [ "desktop", "mobile" ]
		},
		"ext.religiowikiCustomizer.artigos": {
			"styles": [ "resources/css/special-artigos.css" ],
			"scripts": [ "resources/js/special-artigos.js" ],
			"messages": [ "religiowikicustomizer-artigos-delete-jsconfirm" ],
			"targets": [ "desktop", "mobile" ]
		}
	},
	"LogTypes": [ "religiowikicustomizer" ],
	"RestRoutes": [
		{
			"path": "/religiowikicustomizer/v0/theme",
			"method": "GET",
			"class": "MediaWiki\\Extension\\ReligiowikiCustomizer\\Api\\GetThemeHandler"
		},
		{
			"path": "/religiowikicustomizer/v0/theme",
			"method": "PUT",
			"class": "MediaWiki\\Extension\\ReligiowikiCustomizer\\Api\\SaveThemeHandler"
		},
		{
			"path": "/religiowikicustomizer/v0/export",
			"method": "GET",
			"class": "MediaWiki\\Extension\\ReligiowikiCustomizer\\Api\\ExportConfigHandler"
		},
		{
			"path": "/religiowikicustomizer/v0/import",
			"method": "PUT",
			"class": "MediaWiki\\Extension\\ReligiowikiCustomizer\\Api\\ImportConfigHandler"
		}
	],
	"ResourceFileModulePaths": {
		"localBasePath": "",
		"remoteExtPath": "ReligiowikiCustomizer"
	},
	"config": {
		"ReligiowikiCustomizerRight": {
			"value": "editinterface",
			"description": "Direito exigido para acessar Special:ReligiowikiCustomizer. Reaproveita o direito nativo 'editinterface' (já concedido a sysop por padrão) em vez de criar um direito novo — ver Fase 1 do prompt mestre."
		}
	},
	"manifest_version": 2
}
